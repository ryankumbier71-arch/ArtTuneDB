// Use tallest column bottom
cy = max(cy, col1_bot) + 1;

// Separator
gfx_set(atk_red_r, atk_red_g, atk_red_b, 0.4);
gfx_line(lm, cy, gfx_w - rm, cy);
cy += 2;

// === MASTER ===
gfx_setfont(2);
gfx_set(ma_r, ma_g, ma_b, 1);
gfx_x = lm; gfx_y = cy;
gfx_drawstr("Master");
cy += hdr_h;

sl_w4 = (draw_w - 3 * col_gap) / 4;

// Row 1: Crossover frequencies
sx = lm;
gfx_set(gold_r, gold_g, gold_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("Low Cut");
sprintf(0, "%d Hz", lowCut); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w4 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w4, trk_h, lowCut, 20, 2000, gold_r, gold_g, gold_b, 47, 0);

sx = lm + sl_w4 + col_gap;
gfx_set(gold_r, gold_g, gold_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("Low/Mid");
sprintf(0, "%d Hz", xover1); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w4 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w4, trk_h, xover1, 20, 8000, gold_r, gold_g, gold_b, 49, 0);

sx = lm + (sl_w4 + col_gap) * 2;
gfx_set(gold_r, gold_g, gold_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("Mid/High");
sprintf(0, "%d Hz", xover2); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w4 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w4, trk_h, xover2, 100, 20000, gold_r, gold_g, gold_b, 50, 0);

sx = lm + (sl_w4 + col_gap) * 3;
gfx_set(gold_r, gold_g, gold_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("High Cut");
sprintf(0, "%d Hz", highCut); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w4 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w4, trk_h, highCut, 1000, 20000, gold_r, gold_g, gold_b, 48, 0);

cy += sl_row;

// Row 2: Dir Emph | Self Sup | Gain | Smooth | Dry/Wet
sl_w5 = (draw_w - 4 * col_gap) / 5;

sx = lm;
gfx_set(ma_r, ma_g, ma_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("Dir Emph");
sprintf(0, "%.2f", dirEmphasis); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w5 - tw; gfx_y = cy; gfx_drawstr(0);

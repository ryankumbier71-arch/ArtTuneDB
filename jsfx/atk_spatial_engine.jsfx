sx = lm + sl_w3 + col_gap;
gfx_set(ma_r, ma_g, ma_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("LFE Atk");
sprintf(0, "%d ms", lfeAttack); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w3 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w3, trk_h, lfeAttack, 1, 500, ma_r, ma_g, ma_b, 57, 0);

sx = lm + (sl_w3 + col_gap) * 2;
gfx_set(ma_r, ma_g, ma_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("LFE Rel");
sprintf(0, "%d ms", lfeRelease); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w3 - tw; gfx_y = cy; gfx_drawstr(0);
draw_hslider(sx, cy + lbl_h, sl_w3, trk_h, lfeRelease, 50, 2000, ma_r, ma_g, ma_b, 58, 0);

cy += sl_row;

// =============================================
// === MOUSE HANDLING ===
// =============================================

mouse_cap & 1 ? (
  DRAG_STATE[0] == 0 ? (
    si = 0;
    while (si < 59 && DRAG_STATE[0] == 0) (
      sr = SLIDER_RECTS + si * 4;
      mouse_x >= sr[0] && mouse_x <= sr[0] + sr[2] &&
      mouse_y >= sr[1] && mouse_y <= sr[1] + sr[3] ? (
        DRAG_STATE[0] = si + 1;
      );
      si += 1;
    );
  );

  DRAG_STATE[0] > 0 ? (
    si = DRAG_STATE[0] - 1;
    sr = SLIDER_RECTS + si * 4;

    (mouse_cap & 8) ? (
      fine_delta = (mouse_x - LAST_MOUSE_X[0]) * 0.1;
      // cur_norm: map current slider value to 0..1
      si == 0  ? cur_norm = ckSubLow / 5.0 :
      si == 1  ? cur_norm = ckSubMid / 5.0 :
      si == 2  ? cur_norm = ckSubHigh / 5.0 :
      si == 3  ? cur_norm = (ckDuck + 60) / 60 :
      si == 4  ? cur_norm = (ckThresh + 60) / 60 :
      si == 5  ? cur_norm = (ckAttack - 0.1) / 49.9 :
      si == 6  ? cur_norm = (ckRelease - 10) / 490 :
      si == 7  ? cur_norm = ckKnee / 20 :
      si == 8  ? cur_norm = boostLow / 12 :
      si == 9  ? cur_norm = (boostLowFreq - 100) / 700 :
      si == 10 ? cur_norm = (boostLowQ - 0.3) / 2.7 :
      si == 11 ? cur_norm = boostHigh / 18 :
      si == 12 ? cur_norm = (boostHighFreq - 1000) / 4000 :
      si == 13 ? cur_norm = (boostHighQ - 0.3) / 2.7 :
      si == 14 ? cur_norm = (boostAttack - 0.5) / 49.5 :
      si == 15 ? cur_norm = (boostRelease - 10) / 490 :
      si == 16 ? cur_norm = (boostRejectThresh + 40) / 40 :
      si == 17 ? cur_norm = b1Attack :
      si == 18 ? cur_norm = b1Sustain :
      si == 19 ? cur_norm = (b1AtkStr + 1) * 0.5 :
      si == 20 ? cur_norm = (b1SusStr + 1) * 0.5 :
      si == 21 ? cur_norm = (fb1AtkStr + 1) * 0.5 :
      si == 22 ? cur_norm = (fb1SusStr + 1) * 0.5 :
      si == 23 ? cur_norm = (b1ExpThresh + 60) / 60 :
      si == 24 ? cur_norm = (b1ExpRatio - 1) / 19 :
      si == 25 ? cur_norm = (b1ExpFloor + 80) / 70 :
      si == 26 ? cur_norm = cmrLow :
      si == 27 ? cur_norm = b2Attack :
      si == 28 ? cur_norm = b2Sustain :
      si == 29 ? cur_norm = (b2AtkStr + 1) * 0.5 :
      si == 30 ? cur_norm = (b2SusStr + 1) * 0.5 :
      si == 31 ? cur_norm = (fb2AtkStr + 1) * 0.5 :
      si == 32 ? cur_norm = (fb2SusStr + 1) * 0.5 :
      si == 33 ? cur_norm = (b2ExpThresh + 60) / 60 :
      si == 34 ? cur_norm = (b2ExpRatio - 1) / 19 :
      si == 35 ? cur_norm = (b2ExpFloor + 80) / 70 :
      si == 36 ? cur_norm = cmrMid :
      si == 37 ? cur_norm = b3Attack :
      si == 38 ? cur_norm = b3Sustain :
      si == 39 ? cur_norm = (b3AtkStr + 1) * 0.5 :
      si == 40 ? cur_norm = (b3SusStr + 1) * 0.5 :
      si == 41 ? cur_norm = (fb3AtkStr + 1) * 0.5 :
      si == 42 ? cur_norm = (fb3SusStr + 1) * 0.5 :
      si == 43 ? cur_norm = (b3ExpThresh + 60) / 60 :
      si == 44 ? cur_norm = (b3ExpRatio - 1) / 19 :
      si == 45 ? cur_norm = (b3ExpFloor + 80) / 70 :
      si == 46 ? cur_norm = cmrHigh :
      si == 47 ? cur_norm = (lowCut - 20) / 1980 :
      si == 48 ? cur_norm = (highCut - 1000) / 19000 :
      si == 49 ? cur_norm = (xover1 - 20) / 7980 :
      si == 50 ? cur_norm = (xover2 - 100) / 19900 :
      si == 51 ? cur_norm = dirEmphasis :
      si == 52 ? cur_norm = b1SelfSup :
      si == 53 ? cur_norm = (outGain + 20) / 40 :
      si == 54 ? cur_norm = gainSmooth :
      si == 55 ? cur_norm = mix :
      si == 56 ? cur_norm = lfeModDepth :
      si == 57 ? cur_norm = (lfeAttack - 1) / 499 :
      si == 58 ? cur_norm = (lfeRelease - 50) / 1950;
      norm = max(0, min(1, cur_norm + fine_delta / sr[2]));
    ) : (
      norm = max(0, min(1, (mouse_x - sr[0]) / sr[2]));
    );

    // Assign value + automate
    si == 0  ? ( ckSubLow = norm * 5.0;           slider_automate(slider5); ) :
    si == 1  ? ( ckSubMid = norm * 5.0;           slider_automate(slider6); ) :
    si == 2  ? ( ckSubHigh = norm * 5.0;          slider_automate(slider7); ) :
    si == 3  ? ( ckDuck = -60 + norm * 60;        slider_automate(slider8); ) :
    si == 4  ? ( ckThresh = -60 + norm * 60;      slider_automate(slider9); ) :
    si == 5  ? ( ckAttack = 0.1 + norm * 49.9;    slider_automate(slider10); ) :
    si == 6  ? ( ckRelease = 10 + norm * 490;     slider_automate(slider11); ) :
    si == 7  ? ( ckKnee = norm * 20;              slider_automate(slider12); ) :
    si == 8  ? ( boostLow = norm * 12;            slider_automate(slider13); ) :
    si == 9  ? ( boostLowFreq = 100 + norm * 700; slider_automate(slider14); ) :
    si == 10 ? ( boostLowQ = 0.3 + norm * 2.7;   slider_automate(slider15); ) :
    si == 11 ? ( boostHigh = norm * 18;           slider_automate(slider16); ) :
    si == 12 ? ( boostHighFreq = 1000 + norm * 4000; slider_automate(slider17); ) :
    si == 13 ? ( boostHighQ = 0.3 + norm * 2.7;  slider_automate(slider18); ) :
    si == 14 ? ( boostAttack = 0.5 + norm * 49.5; slider_automate(slider19); ) :
    si == 15 ? ( boostRelease = 10 + norm * 490;  slider_automate(slider20); ) :
    si == 16 ? ( boostRejectThresh = -40 + norm * 40; slider_automate(slider21); ) :
    si == 17 ? ( b1Attack = norm;                  slider_automate(slider22); ) :
    si == 18 ? ( b1Sustain = norm;                 slider_automate(slider23); ) :
    si == 19 ? ( b1AtkStr = -1 + norm * 2;        slider_automate(slider24); ) :
    si == 20 ? ( b1SusStr = -1 + norm * 2;        slider_automate(slider25); ) :
    si == 21 ? ( fb1AtkStr = -1 + norm * 2;       slider_automate(slider26); ) :
    si == 22 ? ( fb1SusStr = -1 + norm * 2;       slider_automate(slider27); ) :
    si == 23 ? ( b1ExpThresh = -60 + norm * 60;   slider_automate(slider40); ) :
    si == 24 ? ( b1ExpRatio = 1 + norm * 19;      slider_automate(slider41); ) :
    si == 25 ? ( b1ExpFloor = -80 + norm * 70;    slider_automate(slider42); ) :
    si == 26 ? ( cmrLow = norm;                    slider_automate(slider49); ) :
    si == 27 ? ( b2Attack = norm;                  slider_automate(slider28); ) :
    si == 28 ? ( b2Sustain = norm;                 slider_automate(slider29); ) :
    si == 29 ? ( b2AtkStr = -1 + norm * 2;        slider_automate(slider30); ) :
    si == 30 ? ( b2SusStr = -1 + norm * 2;        slider_automate(slider31); ) :
    si == 31 ? ( fb2AtkStr = -1 + norm * 2;       slider_automate(slider32); ) :
    si == 32 ? ( fb2SusStr = -1 + norm * 2;       slider_automate(slider33); ) :
    si == 33 ? ( b2ExpThresh = -60 + norm * 60;   slider_automate(slider43); ) :
    si == 34 ? ( b2ExpRatio = 1 + norm * 19;      slider_automate(slider44); ) :
    si == 35 ? ( b2ExpFloor = -80 + norm * 70;    slider_automate(slider45); ) :
    si == 36 ? ( cmrMid = norm;                    slider_automate(slider50); ) :
    si == 37 ? ( b3Attack = norm;                  slider_automate(slider34); ) :
    si == 38 ? ( b3Sustain = norm;                 slider_automate(slider35); ) :
    si == 39 ? ( b3AtkStr = -1 + norm * 2;        slider_automate(slider36); ) :
    si == 40 ? ( b3SusStr = -1 + norm * 2;        slider_automate(slider37); ) :
    si == 41 ? ( fb3AtkStr = -1 + norm * 2;       slider_automate(slider38); ) :
    si == 42 ? ( fb3SusStr = -1 + norm * 2;       slider_automate(slider39); ) :
    si == 43 ? ( b3ExpThresh = -60 + norm * 60;   slider_automate(slider46); ) :
    si == 44 ? ( b3ExpRatio = 1 + norm * 19;      slider_automate(slider47); ) :
    si == 45 ? ( b3ExpFloor = -80 + norm * 70;    slider_automate(slider48); ) :
    si == 46 ? ( cmrHigh = norm;                   slider_automate(slider51); ) :
    si == 47 ? ( lowCut = 20 + norm * 1980;        slider_automate(slider1); ) :
    si == 48 ? ( highCut = 1000 + norm * 19000;    slider_automate(slider2); ) :
    si == 49 ? ( xover1 = 20 + norm * 7980;        slider_automate(slider3); ) :
    si == 50 ? ( xover2 = 100 + norm * 19900;      slider_automate(slider4); ) :
    si == 51 ? ( dirEmphasis = norm;               slider_automate(slider52); ) :
    si == 52 ? ( b1SelfSup = norm;                 slider_automate(slider53); ) :
    si == 53 ? ( outGain = -20 + norm * 40;        slider_automate(slider54); ) :
    si == 54 ? ( gainSmooth = norm;                slider_automate(slider55); ) :
    si == 55 ? ( mix = norm;                       slider_automate(slider56); ) :
    si == 56 ? ( lfeModDepth = norm;               slider_automate(slider57); ) :
    si == 57 ? ( lfeAttack = 1 + norm * 499;       slider_automate(slider58); ) :
    si == 58 ? ( lfeRelease = 50 + norm * 1950;    slider_automate(slider59); );

    // Derived values
    out_gain_lin = exp(outGain / DB_K);

    // Crossover coefficient recalculation on drag
    (si >= 47 && si <= 50) ? (
      xover1 = max(xover1, lowCut + 1);
      xover2 = max(xover2, xover1 + 1);
      highCut = max(highCut, xover2 + 1);
      xover2 = min(xover2, highCut - 1);
      xover1 = min(xover1, xover2 - 1);
      lowCut = min(lowCut, xover1 - 1);
      calc_biquad_lp(BIQUAD_COEFF,      lowCut);
      calc_biquad_hp(BIQUAD_COEFF + 5,  lowCut);
      calc_biquad_lp(BIQUAD_COEFF + 10, xover1);
      calc_biquad_hp(BIQUAD_COEFF + 15, xover1);
      calc_biquad_lp(BIQUAD_COEFF + 20, xover2);
      calc_biquad_hp(BIQUAD_COEFF + 25, xover2);
      calc_biquad_lp(BIQUAD_COEFF + 30, highCut);
      calc_biquad_hp(BIQUAD_COEFF + 35, highCut);
    );

    // Boost EQ coefficient recalculation on drag
    (si >= 8 && si <= 13) ? (
      boostLow > 0 ? calc_peaking_eq(BOOST_LOW_COEFF, boostLowFreq, boostLow, boostLowQ);
      boostHigh > 0 ? calc_peaking_eq(BOOST_HI_COEFF, boostHighFreq, boostHigh, boostHighQ);
    );
  );
) : (
  DRAG_STATE[0] = 0;
);

LAST_MOUSE_X[0] = mouse_x;

// === MOUSE WHEEL ===
mouse_wheel != 0 ? (
  mw_handled = 0;
  si = 0;
  while (si < 59 && mw_handled == 0) (
    sr = SLIDER_RECTS + si * 4;
    mouse_x >= sr[0] && mouse_x <= sr[0] + sr[2] &&
    mouse_y >= sr[1] && mouse_y <= sr[1] + sr[3] ? (
      // Default step
      si <= 2 ? ( mw_step = 0.05; ) :
      si <= 7 ? ( mw_step = 0.5; ) :
      si == 8 || si == 11 ? ( mw_step = 0.5; ) :
      si == 9  ? ( mw_step = 10; ) :
      si == 10 || si == 13 ? ( mw_step = 0.1; ) :
      si == 12 ? ( mw_step = 100; ) :
      si == 14 ? ( mw_step = 0.5; ) :
      si == 15 ? ( mw_step = 1; ) :
      si == 16 ? ( mw_step = 0.5; ) :
      si >= 17 && si <= 22 ? ( mw_step = 0.01; ) :
      si >= 23 && si <= 25 ? ( mw_step = 0.5; ) :
      si == 26 ? ( mw_step = 0.01; ) :
      si >= 27 && si <= 32 ? ( mw_step = 0.01; ) :
      si >= 33 && si <= 35 ? ( mw_step = 0.5; ) :
      si == 36 ? ( mw_step = 0.01; ) :
      si >= 37 && si <= 42 ? ( mw_step = 0.01; ) :
      si >= 43 && si <= 45 ? ( mw_step = 0.5; ) :
      si == 46 ? ( mw_step = 0.01; ) :
      si >= 47 && si <= 50 ? ( mw_step = 10; ) :
      si >= 51 && si <= 52 ? ( mw_step = 0.01; ) :
      si == 53 ? ( mw_step = 0.1; ) :
      si == 56 ? ( mw_step = 0.01; ) :
      si == 57 ? ( mw_step = 1; ) :
      si == 58 ? ( mw_step = 1; ) :
      si >= 54 ? ( mw_step = 0.01; );

      mouse_wheel < 0 ? mw_step = -mw_step;

      si == 0  ? ( ckSubLow = max(0, min(5, ckSubLow + mw_step));         slider_automate(slider5); ) :
      si == 1  ? ( ckSubMid = max(0, min(5, ckSubMid + mw_step));         slider_automate(slider6); ) :
      si == 2  ? ( ckSubHigh = max(0, min(5, ckSubHigh + mw_step));       slider_automate(slider7); ) :
      si == 3  ? ( ckDuck = max(-60, min(0, ckDuck + mw_step));           slider_automate(slider8); ) :
      si == 4  ? ( ckThresh = max(-60, min(0, ckThresh + mw_step));       slider_automate(slider9); ) :
      si == 5  ? ( ckAttack = max(0.1, min(50, ckAttack + mw_step));      slider_automate(slider10); ) :
      si == 6  ? ( ckRelease = max(10, min(500, ckRelease + mw_step));    slider_automate(slider11); ) :
      si == 7  ? ( ckKnee = max(0, min(20, ckKnee + mw_step));           slider_automate(slider12); ) :
      si == 8  ? ( boostLow = max(0, min(12, boostLow + mw_step));       slider_automate(slider13); ) :
      si == 9  ? ( boostLowFreq = max(100, min(800, boostLowFreq + mw_step)); slider_automate(slider14); ) :
      si == 10 ? ( boostLowQ = max(0.3, min(3, boostLowQ + mw_step));    slider_automate(slider15); ) :
      si == 11 ? ( boostHigh = max(0, min(18, boostHigh + mw_step));     slider_automate(slider16); ) :
      si == 12 ? ( boostHighFreq = max(1000, min(5000, boostHighFreq + mw_step)); slider_automate(slider17); ) :
      si == 13 ? ( boostHighQ = max(0.3, min(3, boostHighQ + mw_step));  slider_automate(slider18); ) :
      si == 14 ? ( boostAttack = max(0.5, min(50, boostAttack + mw_step)); slider_automate(slider19); ) :
      si == 15 ? ( boostRelease = max(10, min(500, boostRelease + mw_step)); slider_automate(slider20); ) :
      si == 16 ? ( boostRejectThresh = max(-40, min(0, boostRejectThresh + mw_step)); slider_automate(slider21); ) :
      si == 17 ? ( b1Attack = max(0, min(1, b1Attack + mw_step));         slider_automate(slider22); ) :
      si == 18 ? ( b1Sustain = max(0, min(1, b1Sustain + mw_step));       slider_automate(slider23); ) :
      si == 19 ? ( b1AtkStr = max(-1, min(1, b1AtkStr + mw_step));       slider_automate(slider24); ) :
      si == 20 ? ( b1SusStr = max(-1, min(1, b1SusStr + mw_step));       slider_automate(slider25); ) :
      si == 21 ? ( fb1AtkStr = max(-1, min(1, fb1AtkStr + mw_step));     slider_automate(slider26); ) :
      si == 22 ? ( fb1SusStr = max(-1, min(1, fb1SusStr + mw_step));     slider_automate(slider27); ) :
      si == 23 ? ( b1ExpThresh = max(-60, min(0, b1ExpThresh + mw_step)); slider_automate(slider40); ) :
      si == 24 ? ( b1ExpRatio = max(1, min(20, b1ExpRatio + mw_step));   slider_automate(slider41); ) :
      si == 25 ? ( b1ExpFloor = max(-80, min(-10, b1ExpFloor + mw_step)); slider_automate(slider42); ) :
      si == 26 ? ( cmrLow = max(0, min(1, cmrLow + mw_step));           slider_automate(slider49); ) :
      si == 27 ? ( b2Attack = max(0, min(1, b2Attack + mw_step));         slider_automate(slider28); ) :
      si == 28 ? ( b2Sustain = max(0, min(1, b2Sustain + mw_step));       slider_automate(slider29); ) :
      si == 29 ? ( b2AtkStr = max(-1, min(1, b2AtkStr + mw_step));       slider_automate(slider30); ) :
      si == 30 ? ( b2SusStr = max(-1, min(1, b2SusStr + mw_step));       slider_automate(slider31); ) :
      si == 31 ? ( fb2AtkStr = max(-1, min(1, fb2AtkStr + mw_step));     slider_automate(slider32); ) :
      si == 32 ? ( fb2SusStr = max(-1, min(1, fb2SusStr + mw_step));     slider_automate(slider33); ) :
      si == 33 ? ( b2ExpThresh = max(-60, min(0, b2ExpThresh + mw_step)); slider_automate(slider43); ) :
      si == 34 ? ( b2ExpRatio = max(1, min(20, b2ExpRatio + mw_step));   slider_automate(slider44); ) :
      si == 35 ? ( b2ExpFloor = max(-80, min(-10, b2ExpFloor + mw_step)); slider_automate(slider45); ) :
      si == 36 ? ( cmrMid = max(0, min(1, cmrMid + mw_step));           slider_automate(slider50); ) :
      si == 37 ? ( b3Attack = max(0, min(1, b3Attack + mw_step));         slider_automate(slider34); ) :
      si == 38 ? ( b3Sustain = max(0, min(1, b3Sustain + mw_step));       slider_automate(slider35); ) :
      si == 39 ? ( b3AtkStr = max(-1, min(1, b3AtkStr + mw_step));       slider_automate(slider36); ) :
      si == 40 ? ( b3SusStr = max(-1, min(1, b3SusStr + mw_step));       slider_automate(slider37); ) :
      si == 41 ? ( fb3AtkStr = max(-1, min(1, fb3AtkStr + mw_step));     slider_automate(slider38); ) :
      si == 42 ? ( fb3SusStr = max(-1, min(1, fb3SusStr + mw_step));     slider_automate(slider39); ) :
      si == 43 ? ( b3ExpThresh = max(-60, min(0, b3ExpThresh + mw_step)); slider_automate(slider46); ) :
      si == 44 ? ( b3ExpRatio = max(1, min(20, b3ExpRatio + mw_step));   slider_automate(slider47); ) :
      si == 45 ? ( b3ExpFloor = max(-80, min(-10, b3ExpFloor + mw_step)); slider_automate(slider48); ) :
      si == 46 ? ( cmrHigh = max(0, min(1, cmrHigh + mw_step));         slider_automate(slider51); ) :
      si == 47 ? ( lowCut = max(20, min(2000, lowCut + mw_step));         slider_automate(slider1); ) :
      si == 48 ? ( highCut = max(1000, min(20000, highCut + mw_step));   slider_automate(slider2); ) :
      si == 49 ? ( xover1 = max(20, min(8000, xover1 + mw_step));       slider_automate(slider3); ) :
      si == 50 ? ( xover2 = max(100, min(20000, xover2 + mw_step));     slider_automate(slider4); ) :
      si == 51 ? ( dirEmphasis = max(0, min(1, dirEmphasis + mw_step));  slider_automate(slider52); ) :
      si == 52 ? ( b1SelfSup = max(0, min(1, b1SelfSup + mw_step));     slider_automate(slider53); ) :
      si == 53 ? ( outGain = max(-20, min(20, outGain + mw_step));       slider_automate(slider54); ) :
      si == 54 ? ( gainSmooth = max(0, min(1, gainSmooth + mw_step));    slider_automate(slider55); ) :
      si == 55 ? ( mix = max(0, min(1, mix + mw_step));                  slider_automate(slider56); ) :
      si == 56 ? ( lfeModDepth = max(0, min(1, lfeModDepth + mw_step)); slider_automate(slider57); ) :
      si == 57 ? ( lfeAttack = max(1, min(500, lfeAttack + mw_step));   slider_automate(slider58); ) :
      si == 58 ? ( lfeRelease = max(50, min(2000, lfeRelease + mw_step)); slider_automate(slider59); );

      out_gain_lin = exp(outGain / DB_K);

      (si >= 47 && si <= 50) ? (
        xover1 = max(xover1, lowCut + 1);
        xover2 = max(xover2, xover1 + 1);
        highCut = max(highCut, xover2 + 1);
        xover2 = min(xover2, highCut - 1);
        xover1 = min(xover1, xover2 - 1);
        lowCut = min(lowCut, xover1 - 1);
        calc_biquad_lp(BIQUAD_COEFF,      lowCut);
        calc_biquad_hp(BIQUAD_COEFF + 5,  lowCut);
        calc_biquad_lp(BIQUAD_COEFF + 10, xover1);
        calc_biquad_hp(BIQUAD_COEFF + 15, xover1);
        calc_biquad_lp(BIQUAD_COEFF + 20, xover2);
        calc_biquad_hp(BIQUAD_COEFF + 25, xover2);
        calc_biquad_lp(BIQUAD_COEFF + 30, highCut);
        calc_biquad_hp(BIQUAD_COEFF + 35, highCut);
      );

      (si >= 8 && si <= 13) ? (
        boostLow > 0 ? calc_peaking_eq(BOOST_LOW_COEFF, boostLowFreq, boostLow, boostLowQ);
        boostHigh > 0 ? calc_peaking_eq(BOOST_HI_COEFF, boostHighFreq, boostHigh, boostHighQ);
      );

      mw_handled = 1;
    );
    si += 1;
  );
  mouse_wheel = 0;
);

draw_hslider(cx, cy + lbl_h, sl_wc, trk_h, b3Attack, 0, 1, gold_r, gold_g, gold_b, 37, 0);
cy += sl_row;
gfx_set(1, 1, 1, 0.9); gfx_x = cx; gfx_y = cy; gfx_drawstr("Sustain Speed");

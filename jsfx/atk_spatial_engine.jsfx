cy += sl_row;

// Row 3: LFE sidechain
sx = lm;
gfx_set(ma_r, ma_g, ma_b, 0.9); gfx_x = sx; gfx_y = cy; gfx_drawstr("LFE Depth");
sprintf(0, "%.2f", lfeModDepth); gfx_measurestr(0, tw, th); gfx_x = sx + sl_w3 - tw; gfx_y = cy; gfx_drawstr(0);
